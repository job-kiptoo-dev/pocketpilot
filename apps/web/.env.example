# Supabase — from Project Settings → API.
# When these are unset, the app runs in local-seed mode (no auth, no realtime).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never exposed to the client). Used for admin/seed scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI Gateway — enables the LLM assistant (without it, the assistant uses
# the offline rule engine). Get a key at vercel.com/ai-gateway. Optional model override.
AI_GATEWAY_API_KEY=
# POCKETPILOT_AI_MODEL=anthropic/claude-sonnet-4-6
